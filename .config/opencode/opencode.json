{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "plugin": ["@plannotator/opencode@latest"],
  "mcp": {
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true
    },
    "grep_app": {
      "type": "remote",
      "url": "https://mcp.grep.app",
      "enabled": true
    },
    "opensrc": {
      "type": "local",
      "command": ["npx", "-y", "opensrc-mcp"],
      "enabled": true
    }
  },
  "tools": {
    "context7_*": false,
    "grep_app_*": false,
    "opensrc_*": false
  },
  "agent": {
    "librarian": {
      "tools": {
        "context7_*": true,
        "grep_app_*": true,
        "opensrc_*": true
      }
    }
  },
  "provider": {
    "openai": {
      "options": {
        "baseURL": "http://127.0.0.1:8317/v1",
        "apiKey": "{env:CLI_PROXY_API_KEY}"
      }
    }
  },
  "small_model": "opencode-go/qwen3.5-plus"
}
